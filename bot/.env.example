# NeuraWealth OS Telegram Bot — Environment Variables
# ====================================================
# Copy this file to .env and fill in your values.

# Required: Your Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: CoinGecko API key (for higher rate limits)
# Get one free at https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# Optional: SQLite database path (defaults to neurawealth.db)
DATABASE_PATH=neurawealth.db

# Optional: Stripe integration for payments
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Optional: Stripe payment links for subscription tiers
STRIPE_PREMIUM_LINK=https://buy.stripe.com/your_premium_link
STRIPE_ENTERPRISE_LINK=https://buy.stripe.com/your_enterprise_link

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
