# NeuraWealth OS Telegram Bot — Environment Variables
# ====================================================
# Copy this file to .env and fill in your values.

# Required: Your Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: CoinGecko API key (for higher rate limits)
# Get one free at https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# Optional: SQLite database path (defaults to neurawealth.db)
DATABASE_PATH=neurawealth.db

# ── Stripe ────────────────────────────────────────────────────────────────────
# Your Stripe Secret Key (sk_live_... for production, sk_test_... for testing)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Webhook signing secret — get from Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Stripe Product & Price IDs (auto-created — do not change unless recreating)
STRIPE_PREMIUM_PRODUCT_ID=prod_UGp7kjYfqjD5nF
STRIPE_PREMIUM_PRICE_ID=price_1TIHTe04ZWF3w3YV7NoScf1M
STRIPE_ENTERPRISE_PRODUCT_ID=prod_UGp7AAwipK67sq
STRIPE_ENTERPRISE_PRICE_ID=price_1TIHTg04ZWF3w3YV1o5yiywR

# Stripe Payment Link URLs (tap-to-pay links shown in /subscribe)
STRIPE_PREMIUM_LINK=https://buy.stripe.com/5kQfZ989m66Ua9B7mnfjG02
STRIPE_ENTERPRISE_LINK=https://buy.stripe.com/bJe3cn61e3YM3LdcGHfjG03

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
