# NeuraWealth OS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# ─── Server ──────────────────────────────────────────────────────────────────

# HTTP port the production server listens on (default: 3000)
PORT=3000

# Node environment: "development" | "production"
NODE_ENV=development

# ─── Analytics (optional) ─────────────────────────────────────────────────────
# Self-hosted Umami analytics (https://umami.is)
# Leave blank to disable analytics.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ─── CoinGecko (optional) ─────────────────────────────────────────────────────
# Free tier works without an API key but has strict rate limits.
# Get a Pro key at https://www.coingecko.com/en/api/pricing
VITE_COINGECKO_API_KEY=

# ─── Telegram Bot (optional) ──────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram to get your token.
# ⚠ VITE_ prefix embeds this in the client bundle — do not use this for
#   sensitive server-side operations. Move to a non-VITE_ variable and handle
#   webhook calls on the server instead.
VITE_TELEGRAM_BOT_TOKEN=

# ─── Google Maps (optional) ───────────────────────────────────────────────────
# Required for the interactive Map feature.
# Restrict this key to your domain in the Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY=

# ─── X/Twitter API (optional) ────────────────────────────────────────────────
# Credentials from developer.x.com for automated posting via twitter_bot.py
# See https://developer.x.com/en/docs/authentication for setup instructions.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
