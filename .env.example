# Environment Variables for NeuraWealth OS
# Copy this file to .env and fill in values as needed.
# VITE_ prefixed variables are embedded in the client bundle at build time.
# Variables without VITE_ prefix are server-side only and never exposed to the browser.

# ─────────────────────────────────────────────
# Analytics (optional — uses Umami self-hosted)
# ─────────────────────────────────────────────
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Server-side analytics endpoint used to set the Content-Security-Policy
# script-src directive. Set this to the same base URL as VITE_ANALYTICS_ENDPOINT.
ANALYTICS_ENDPOINT=

# ─────────────────────────────────────────────
# Telegram Bot (server-side ONLY — never use VITE_ prefix)
# Keep this secret. Exposing it in the client bundle gives anyone full
# control over your Telegram bot.
# Get your token from @BotFather: https://t.me/botfather
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram chat IDs that the /api/telegram/send proxy
# is permitted to forward messages to. This is a server-side-only allowlist
# that prevents the proxy from being used as an open relay. Include every
# channel or group chat ID the bot should post to
# (e.g. TELEGRAM_ALLOWED_CHAT_IDS=-1001234567890,987654321).
# If this variable is unset the proxy returns 503.
TELEGRAM_ALLOWED_CHAT_IDS=

# ─────────────────────────────────────────────
# Data APIs
# ─────────────────────────────────────────────
# CoinGecko Pro API key (optional — unlocks higher rate limits)
# Free tier: 30 req/min. Pro: https://www.coingecko.com/en/api/pricing
VITE_COINGECKO_API_KEY=

# Google Maps API key (required for Mining Claim map view)
# Enable "Maps JavaScript API" in Google Cloud Console
VITE_GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────
# Platform identity (optional)
# ─────────────────────────────────────────────
VITE_APP_ID=neurawealth-os

# ─────────────────────────────────────────────
# Integration endpoints (optional)
# ─────────────────────────────────────────────
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_OAUTH_PORTAL_URL=

# ─── X/Twitter API (optional) ────────────────────────────────────────────────
# Credentials from developer.x.com for automated posting via twitter_bot.py
# See https://developer.x.com/en/docs/authentication for setup instructions.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Server configuration (production)
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development
