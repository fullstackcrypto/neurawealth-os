# ── Server (Railway) ─────────────────────────────────────────────────────────
# Telegram bot token — NEVER prefix with VITE_ (would expose to client bundle)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Shared secret to authenticate the Telegram proxy endpoint.
# Generate a strong random value: openssl rand -hex 32
# NEVER prefix with VITE_ — this must stay server-side only.
TELEGRAM_PROXY_SECRET=

# Port (Railway sets this automatically)
PORT=3000

# Analytics endpoint (Umami self-hosted)
ANALYTICS_ENDPOINT=https://analytics.your-domain.com/script.js

# ── Client (Vercel, VITE_ prefix = exposed to browser) ──────────────────────
# CoinGecko API key (optional — free tier works without one)
VITE_COINGECKO_API_KEY=

# Telegram proxy secret (must match TELEGRAM_PROXY_SECRET above)
VITE_TELEGRAM_PROXY_SECRET=

# Frontend Forge integration (optional)
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# OAuth portal (optional — only if using auth)
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=

# ── Vercel deployment secrets (GitHub Actions) ───────────────────────────────
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
