# ── Server (Railway) ─────────────────────────────────────────────────────────
# Telegram bot token — NEVER prefix with VITE_ (would expose to client bundle)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Port (Railway sets this automatically)
PORT=3000

# Analytics endpoint (Umami self-hosted)
ANALYTICS_ENDPOINT=https://analytics.your-domain.com/script.js

# ── Client (Vercel, VITE_ prefix = exposed to browser) ──────────────────────
# CoinGecko API key (optional — free tier works without one)
VITE_COINGECKO_API_KEY=

# Frontend Forge integration (optional)
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# OAuth portal (optional — only if using auth)
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=

# ── Vercel deployment secrets (GitHub Actions) ───────────────────────────────
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=

# ── Backend URL reference ─────────────────────────────────────────────────────
# The Railway backend URL is hardcoded in the `vercel.json` rewrite destination.
# Update the /api/:path* destination in vercel.json to match your Railway URL,
# e.g. https://neurawealth-os.up.railway.app or https://api.neurawealth-os.xyz
# RAILWAY_BACKEND_URL=https://api.neurawealth-os.xyz
